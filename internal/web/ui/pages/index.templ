package pages

import "github.com/PhoenixTech2003/go-blog/internal/web/ui/layouts"

templ Index(randomQoute string) {
	@layouts.Base() {
		<main class="grow flex flex-col items-center justify-center pt-32 pb-40 px-margin-mobile md:px-gutter">
			<div class="w-full max-w-reading-max flex flex-col items-center text-center">
				{ randomQoute }
			</div>
		</main>
	}
}
