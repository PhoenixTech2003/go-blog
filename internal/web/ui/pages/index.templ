package pages

import "github.com/PhoenixTech2003/go-blog/internal/web/ui/layouts"
import "github.com/PhoenixTech2003/go-blog/internal/web/ui/components"

templ Index() {
	@layouts.Base() {
		<main class="max-w-container-max mx-auto px-margin-mobile md:px-gutter mt-12 mb-24">
			@components.SortFilterHeader()
			@components.ArticleGrid()
		</main>
	}
}
